# Azure Cognitive Services Speech API Key
AZURE_SPEECH_KEY=your_azure_speech_key_here

# MiniMax API Key (for AI-powered subtitle segmentation)
MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API Key (alternative AI provider for subtitle segmentation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Hugging Face Token (for downloading Whisper models from Hugging Face Hub)
HF_TOKEN=your_huggingface_token_here

# Character voice configurations
# Format: CHARACTER_NAME_VOICE=voice_name
小悦_VOICE=zh-CN-Xiaoxiao2:DragonHDFlashLatestNeural
Leo_VOICE=zh-CN-Yunyi:DragonHDFlashLatestNeural
